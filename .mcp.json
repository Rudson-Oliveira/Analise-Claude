{
  "mcpServers": {
    "n8n-local": {
      "command": "npx",
      "args": ["-y", "n8n-mcp"],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "${N8N_LOCAL_URL:-http://localhost:5678}",
        "N8N_API_KEY": "${N8N_LOCAL_API_KEY}"
      }
    },
    "n8n-cloud": {
      "command": "npx",
      "args": ["-y", "n8n-mcp"],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "${N8N_CLOUD_URL:-https://rudsonoliveira2323.app.n8n.cloud}",
        "N8N_API_KEY": "${N8N_CLOUD_API_KEY}"
      }
    }
  }
}
